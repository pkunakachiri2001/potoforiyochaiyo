# .htaccess - Advanced SEO Configuration for Apache Servers
# Enable Gzip Compression for faster page loads (SEO factor)
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json
</IfModule>

# Add Cache Control Headers (Improves SEO through faster load times)
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/html "access plus 1 week"
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/gif "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType font/ttf "access plus 1 year"
  ExpiresByType font/woff "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
</IfModule>

# Disable ETag (Improves caching)
<IfModule mod_headers.c>
  Header unset ETag
  FileETag None
</IfModule>

# Enable HTTPS (Security is an SEO ranking factor)
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteCond %{HTTPS} off
  RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
</IfModule>

# Remove www and redirect to non-www (Consistency for SEO)
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteCond %{HTTP_HOST} ^www\.(.*)$ [NC]
  RewriteRule ^(.*)$ https://%1/$1 [R=301,L]
</IfModule>

# Allow access to robots.txt and sitemap.xml
<Files robots.txt>
  Allow from all
</Files>
<Files sitemap.xml>
  Allow from all
</Files>

# Add Security Headers
<IfModule mod_headers.c>
  # Prevent MIME type sniffing
  Header set X-Content-Type-Options "nosniff"
  
  # Enable XSS protection
  Header set X-XSS-Protection "1; mode=block"
  
  # Clickjacking prevention
  Header set X-Frame-Options "SAMEORIGIN"
  
  # Content Security Policy (lightweight version for better compatibility)
  Header set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https:; style-src 'self' 'unsafe-inline' https:; img-src 'self' data: https:; font-src 'self' data: https:; connect-src 'self' https:;"
</IfModule>

# Deny access to sensitive files
<FilesMatch "\.env$|\.git|composer.json|composer.lock|\.htaccess$|readme.md$|\.yml$|\.yaml$">
  Order allow,deny
  Deny from all
</FilesMatch>

# Enable mod_headers for better caching
<IfModule mod_headers.c>
  Header set Cache-Control "public, max-age=31536000" ".jpg .jpeg .png .gif .ico .css .js .svg"
  Header set Vary "Accept-Encoding"
</IfModule>

# Pretty URLs (Remove .html extension for cleaner SEO-friendly URLs)
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^([^\.]+)$ $1.html [NC,L]
</IfModule>

# Custom 404 error page
ErrorDocument 404 /404.html

# Disable directory listing (Security best practice)
Options -Indexes

# Add custom headers for SEO
<IfModule mod_headers.c>
  # Tell search engines this is a mobile-friendly site
  Header set X-Mobile-Web-App-Capable "yes"
  Header set X-UA-Compatible "IE=edge"
</IfModule>
